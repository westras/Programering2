        "## 8. RäknareSkapa `counter.txt` som håller koll på hur många gånger programmet körts."
      ],
      "id": "_c9NIXZWBKn3"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "_lWpRW_yBKn3",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "6f602235-4540-42d4-adcf-b8f2eb42a295"
      },
      "source": [
        "ProgKörts = 0\n",
        "\n",
        "try:\n",
        "    with open('counter.txt', 'r', encoding='utf-8') as f:\n",
        "        innehåll = f.read().strip()\n",
        "        if innehåll: # finns inget att lägga til görs det inte\n",
        "            ProgKörts = int(innehåll)\n",
        "except (FileNotFoundError, ValueError):\n",
        "    # om inget innehåll finns så stannar progkörts på 0\n",
        "    pass\n",
        "\n",
        "# annars ökar progkörts med 1\n",
        "ProgKörts += 1\n",
        "\n",
        "# Sen skriver vi att programmet har körts i filen\n",
        "with open('counter.txt', 'w', encoding='utf-8') as f:\n",
        "    f.write(str(ProgKörts))\n",
        "\n",
        "print(f\"Programmet körts {ProgKörts} gånger.\") #och printar resultatet"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Programmet körts 1 gånger.\n"
          ]
        }
