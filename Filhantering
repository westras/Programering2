        "## 10. Räkna rader i alla txt-filerAnvänd pathlib och glob."
      ],
      "id": "kptaoIdBBKn3"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "mQRKU0Y9BKn3",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "68a9bebf-7387-4b4b-fb72-60a4db705368"
      },
      "source": [
        "from pathlib import Path #hämta pathlib\n",
        "\n",
        "current_directory = Path('.')\n",
        "\n",
        "for file_path in current_directory.glob('*.txt'):#kollar efter txt filer i directory\n",
        "    if file_path.is_file():\n",
        "        try:\n",
        "            with open(file_path, 'r', encoding='utf-8') as f:\n",
        "                lines = f.readlines()\n",
        "                print(f\"Fil: {file_path.name}, Antal rader: {len(lines)}\") #om vi hittar en prövar vi öppna och läsa rader\n",
        "        except Exception as e:\n",
        "            print(f\"Kunde inte läsa fil {file_path.name}: {e}\") #anasr ger vi fel meddelande"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
